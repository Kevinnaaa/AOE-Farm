-- UNIVERSAL ANTI AFK
-- =============================================
local function antiAFKLoop()
    task.spawn(function()
        while ScriptActive do
            if AntiAFKEnabled then
                pcall(function()
                    local char = LocalPlayer.Character
                    if char then
                        if not originalPosition then
                            local root = char:FindFirstChild("HumanoidRootPart")
                            if root then originalPosition = root.CFrame end
                        end
                        local humanoid = char:FindFirstChild("Humanoid")
                        local root = char:FindFirstChild("HumanoidRootPart")
                        if humanoid and root and originalPosition then
                            humanoid.Jump = true
                            local targetPos = originalPosition.Position + Vector3.new(math.random(-20,20), 0, math.random(-20,20))
                            humanoid:MoveTo(targetPos)
                            task.wait(3)
                            humanoid:MoveTo(originalPosition.Position)
                            task.wait(3)
                        end
                    end
                end)
            end
            task.wait(840)
        end
    end)
end

