-- =============================================
-- UNIVERSAL ANTI AFK (Works on PC & Mobile)
-- =============================================
local function AntiAFK()
    task.spawn(function()
        while ScriptActive and AntiAFKEnabled do
            pcall(function()
                local char = LocalPlayer.Character
                if char then
                    -- Method 1: Jump
                    if char:FindFirstChild("Humanoid") then
                        char.Humanoid.Jump = true
                    end
                    
                    -- Method 2: Small camera rotation
                    local camera = workspace.CurrentCamera
                    if camera then
                        camera.CFrame = camera.CFrame * CFrame.Angles(math.rad(0.5), math.rad(0.5), 0)
                    end
                    
                    -- Method 3: Tiny movement
                    local root = char:FindFirstChild("HumanoidRootPart")
                    if root then
                        root.CFrame = root.CFrame * CFrame.new(0.1, 0, 0.1)
                    end
                    
                    -- Method 4: Virtual key press (PC)
                    if not isMobile then
                        VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.Space, false, game)
                        task.wait(0.1)
                        VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.Space, false, game)
                    end
                    
                    -- Method 5: Touch simulation (Mobile)
                    if isMobile then
                        VirtualInputManager:SendTouchEvent(Vector2.new(100, 100), 0, true, game)
                        task.wait(0.05)
                        VirtualInputManager:SendTouchEvent(Vector2.new(100, 100), 0, false, game)
                    end
                end
            end)
            task.wait(900) -- Every 15 minutes
        end
    end)
end

